	// Método para cargar la imagen según el índice
	private void cambiarImagen(int indice) {
	    try {
	        ImageIcon icon = new ImageIcon("img/img" + indice + ".png");
	        lblimageCarro.setIcon(icon);
	    } catch (Exception e) {
	        lblimageCarro.setIcon(null); // Si no encuentra la foto, queda vacío
	    }
	}
	

	public void actionPerformed(ActionEvent e) {
		if (e.getSource() == cboMarca) {
			actionPerformedCboCodigo(e);
		}
		if (e.getSource() == btnCerrar) {
			actionPerformedBtnCerrar(e);
		}
	}

	protected void actionPerformedBtnCerrar(ActionEvent e) {
		
