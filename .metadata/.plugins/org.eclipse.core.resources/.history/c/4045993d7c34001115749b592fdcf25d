package Proyecto;

import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

import javax.swing.DefaultComboBoxModel;
import javax.swing.JButton;
import javax.swing.JComboBox;
import javax.swing.JDialog;
import javax.swing.JLabel;
import javax.swing.JScrollPane;
import javax.swing.JTextArea;
import javax.swing.JTextField;
import javax.swing.UIManager;

public class DialogoVenta extends JDialog implements ActionListener {
	/**
	 * 
	 */
	private static final long serialVersionUID = 1L;
	private JButton btnProcesar;
	private JScrollPane scp;
	private JComboBox<String> cboMarca;
	private JLabel lblMarca;
	private JLabel lblPrecio;
	private JLabel lblCantidad;
	private JTextField txtPrecio;
	private JTextField txtCantidad;
	private JTextArea txtS;
	private JButton btnCerrar;
	private JTextField txtModelo;
	private JLabel lblModelo;

	/**
	 * Launch the application.
	 */
	public static void main(String[] args) {
		try {
			UIManager.setLookAndFeel("com.sun.java.swing.plaf.windows.WindowsLookAndFeel");
		} catch (Throwable e) {
			e.printStackTrace();
		}
		try {
			DialogoVenta dialog = new DialogoVenta();
			dialog.setDefaultCloseOperation(JDialog.DISPOSE_ON_CLOSE);
			dialog.setVisible(true);
		} catch (Exception e) {
			e.printStackTrace();
		}
	}

	/**
	 * Create the dialog.
	 */
	public DialogoVenta() {
		setResizable(false);
		setTitle("Venta de Veh\u00EDculos");
		setBounds(100, 100, 527, 429);
		getContentPane().setLayout(null);
		
		btnProcesar = new JButton("Vender");
		btnProcesar.addActionListener(this);
		btnProcesar.setBounds(388, 55, 89, 23);
		getContentPane().add(btnProcesar);
		
		scp = new JScrollPane();
		scp.setBounds(33, 155, 444, 214);
		getContentPane().add(scp);
		
		txtS = new JTextArea();
		txtS.setEditable(false);
		scp.setViewportView(txtS);
		
		cboMarca = new JComboBox<String>();
		cboMarca.addActionListener(this);
		cboMarca.setBounds(157, 11, 111, 23);
		cboMarca.setModel(new DefaultComboBoxModel<String>(new String[] {"TOYOTA", "HYUNDAI", "HONDA", "KIA", "MAZDA"}));
		getContentPane().add(cboMarca);
		
		lblMarca = new JLabel("Marca");
		lblMarca.setBounds(33, 15, 71, 14);
		getContentPane().add(lblMarca);
		
		lblPrecio = new JLabel("Precio ($.)");
		lblPrecio.setBounds(33, 81, 71, 14);
		getContentPane().add(lblPrecio);
		
		lblCantidad = new JLabel("Cantidad ");
		lblCantidad.setBounds(33, 115, 83, 14);
		getContentPane().add(lblCantidad);
		
		txtPrecio = new JTextField();
		txtPrecio.setEditable(false);
		txtPrecio.setBounds(157, 78, 111, 20);
		getContentPane().add(txtPrecio);
		txtPrecio.setColumns(10);
		//Aqui se colocó para que se muestre a la hora de abrir la ventada la info de la primera marca
		txtPrecio.setText(String.format("%.2f",Menu_Principal.precio0));
		
		txtCantidad = new JTextField();
		txtCantidad.setBounds(157, 112, 111, 20);
		getContentPane().add(txtCantidad);
		txtCantidad.setColumns(10);
		
		btnCerrar = new JButton("Cerrar");
		btnCerrar.addActionListener(this);
		btnCerrar.setBounds(388, 89, 89, 23);
		getContentPane().add(btnCerrar);
		
		txtModelo = new JTextField();
		txtModelo.setEditable(false);
		txtModelo.setColumns(10);
		txtModelo.setBounds(157, 44, 111, 20);
		getContentPane().add(txtModelo);
		txtModelo.setText(Menu_Principal.modelo0);
		
		lblModelo = new JLabel("Modelo");
		lblModelo.setBounds(33, 47, 46, 14);
		getContentPane().add(lblModelo);
	}
	
	public void actionPerformed(ActionEvent e) {
		if (e.getSource() == btnProcesar) {
			actionPerformedBtnProcesar(e);
		}
		if (e.getSource() == cboMarca) {
			actionPerformedCboMarca(e);
		}
		if (e.getSource() == btnCerrar) {
			actionPerformedBtnCerrar(e);
		}
	}
	protected void actionPerformedBtnCerrar(ActionEvent e) {
		dispose();
	}
	
	//Aqui se coloca los datos a mostrar en los textarea sin editar. 
	protected void actionPerformedCboMarca(ActionEvent e) 
	{
		switch (cboMarca.getSelectedIndex()) 
		{
		case 0:
			txtPrecio.setText(String.format("%.2f",Menu_Principal.precio0));
			txtModelo.setText(Menu_Principal.modelo0);
			break;
		case 1:
			txtPrecio.setText(String.format("%.2f",Menu_Principal.precio1));
			txtModelo.setText(Menu_Principal.modelo1);
			break;
		case 2:
			txtPrecio.setText(String.format("%.2f",Menu_Principal.precio2));
			txtModelo.setText(Menu_Principal.modelo2);
			break;
		case 3:
			txtPrecio.setText(String.format("%.2f",Menu_Principal.precio3));
			txtModelo.setText(Menu_Principal.modelo3);
			break;
		default:
			txtPrecio.setText(String.format("%.2f",Menu_Principal.precio4));
			txtModelo.setText(Menu_Principal.modelo4);
			break;
		}
		
		
	}
	protected void actionPerformedBtnProcesar(ActionEvent e) 
	
	{

		//Declaracion de Variables
		
		String marca, obsequio;
		double precio, porceApli, impComp, impDes, impPag;
		int cantidad; 
		
		
		// Datos de entrada
		marca = cboMarca.getSelectedItem().toString();
		precio = Double.parseDouble(txtPrecio.getText());
		cantidad = Integer.parseInt(txtCantidad.getText());
		
				
				
		// Aplicamos Operacion de Descuentos
		if (cantidad >= 1 && cantidad <= 5) {
		    porceApli = Menu_Principal.porcentaje1;
		} 
		else if (cantidad >= 6 && cantidad <= 10) {
		    porceApli = Menu_Principal.porcentaje2;
		} 
		else if (cantidad >= 11 && cantidad <= 15) {
		    porceApli = Menu_Principal.porcentaje3;
		} 
		else { // Más de 15
		    porceApli = Menu_Principal.porcentaje4;
		}
		
		// Aplicamos Operacion de Obsequios
		if (cantidad == 1) {
		    obsequio = Menu_Principal.Obsequio1;
		} // de 2 a 5
		else if (cantidad >= 2 && cantidad <= 5) {
		    obsequio = Menu_Principal.Obsequio2;
		}		 
		else { // Más de 5
		    obsequio = Menu_Principal.Obsequio3;
		}

		// Cálculos finales
		impComp = precio * cantidad;
		impDes = impComp * (porceApli / 100);
		impPag = impComp - impDes;
		
		txtS.setText("BOLETA DE VENTA\n\n");
		txtS.append("Marca\t\t\t\t: " + marca + "\n");
		txtS.append("Precio\t\t\t\t: S/. " + String.format("%.2f", precio) + "\n");
		txtS.append("Cantidad\t\t\t: " + cantidad + "\n");
		txtS.append("Importe Compra\t\t\t: S/. " + String.format("%.2f", impComp) + "\n");
		txtS.append("Importe Descuento (" + porceApli + "%)\t: S/. " + String.format("%.2f", impDes) + "\n");
		txtS.append("Importe a Pagar\t\t\t: S/. " + String.format("%.2f", impPag) + "\n");
		txtS.append("Obsequio\t\t\t: " + obsequio + "\n");
		txtS.setCaretPosition(0);
		
		
		
	}
}

